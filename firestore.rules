// firestore.rules
// Deploy with: firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: can read own profile, write own profile
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Drivers: anyone can read (to see listings), only the driver writes their own profile
    match /drivers/{driverId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == driverId;
    }

    // Ratings: anyone can read, authenticated clients can write
    match /ratings/{ratingId} {
      allow read: if true;
      allow write: if request.auth != null
        && ratingId == (request.resource.data.driverUid + '_' + request.auth.uid)
        && request.resource.data.clientUid == request.auth.uid
        && request.resource.data.stars is int
        && request.resource.data.stars >= 1
        && request.resource.data.stars <= 5;
    }
  }
}
